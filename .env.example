# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Required — get at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (choose one) ────────────────────────────────────────────────────────
# Option A: Gmail (enable "App Password" in Google Account → Security)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Option B: Generic SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
# Optional — get at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567

# ── Vapi (Voice AI) ───────────────────────────────────────────────────────────
# Required for voice calls — get at https://vapi.ai
VAPI_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAPI_PHONE_NUMBER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: ElevenLabs voice ID (default: Sarah)
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty for *)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
